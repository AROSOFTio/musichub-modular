NODE_ENV=development
PORT=4000
NEXT_PUBLIC_APP_URL=https://music.arosoft.io
NEXT_PUBLIC_API_URL=https://music.arosoft.io/api
API_INTERNAL_URL=http://api:4000/api
FRONTEND_URL=https://music.arosoft.io

POSTGRES_DB=musichub
POSTGRES_USER=musichub
POSTGRES_PASSWORD=change_me
# If POSTGRES_PASSWORD contains reserved URL characters such as @ or :, URL-encode it here.
DATABASE_URL=postgresql://musichub:change_me@postgres:5432/musichub?schema=public

REDIS_URL=redis://redis:6379

JWT_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

ADMIN_EMAIL=admin@music.arosoft.io
ADMIN_PASSWORD=replace_with_a_strong_password
ADMIN_DISPLAY_NAME=Musichub Admin
DEV_ADMIN_EMAIL=dev@music.arosoft.io
DEV_ADMIN_PASSWORD=replace_with_a_strong_dev_password
DEV_ADMIN_DISPLAY_NAME=MusicHub Developer
UPLOAD_DIR=/app/uploads
